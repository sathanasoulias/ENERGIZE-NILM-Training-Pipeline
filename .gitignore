data/PlegmaDataset_Clean/
data/CLEAN_REFIT_081116/
data/processed/

# Keep the data scripts and parsers
!data/data.py
!data/dataset_management/

# =============================================================================
# Outputs — selectively track only model.pt checkpoints and metrics
# =============================================================================
outputs/**

# Unignore the specific subdirectories and files we want tracked
!outputs/*/
!outputs/*/checkpoint/
!outputs/*/checkpoint/model.pt
!outputs/*/metrics/
!outputs/*/metrics/**

